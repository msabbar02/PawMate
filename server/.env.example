# ═══════════════════════════════════════════
# PawMate Server - Environment Variables
# ═══════════════════════════════════════════
# Copy this file to .env and fill with your real values.

PORT=3000

# ── Supabase ──────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=your_supabase_service_role_key_here

# ── Resend ───────────────────────────────
RESEND_API_KEY=re_your_resend_api_key_here
EMAIL_FROM=PawMate <noreply@apppawmate.com>
EMAIL_FROM_SUPPORT=PawMate Soporte <soporte@apppawmate.com>
EMAIL_FROM_ADMIN=PawMate Admin <admin@apppawmate.com>

# ── Supabase Auth Hook ────────────────────
SUPABASE_AUTH_HOOK_SECRET=v1,whsec_your_hook_secret_here

# ── Stripe (test mode) ────────────────────
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key_here
