# ============================================
# PawMate · .gitignore principal
# ============================================

# ============================================
# ARCHIVOS SENSIBLES Y CLAVES
# ============================================
# Supabase
**/supabase/.branches/
**/supabase/.temp/
**/supabase-service-key*

# Variables de entorno
.env
.env.*
**/.env
**/.env.*
!.env.example
!**/.env.example

# Claves de API y secretos
**/*secret*
**/*credentials*
**/*apikey*
**/secrets/
**/serviceAccountKey*.json

# ============================================
# DEPENDENCIAS Y NODE_MODULES
# ============================================
node_modules/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
lerna-debug.log*
.pnpm-debug.log*

# Lockfiles de gestores de paquetes
package-lock.json
yarn.lock
pnpm-lock.yaml

# ============================================
# APP MÓVIL (React Native / Expo)
# ============================================
# Expo
.expo/
.expo-shared/
dist/
web-build/

# Android
mobile/android/app/build/
mobile/android/build/
mobile/android/.gradle/
mobile/android/local.properties
mobile/android/.idea/
mobile/android/*.iml
mobile/android/*.hprof
mobile/android/.cxx/
mobile/android/app/release/
mobile/android/app/debug/

# iOS
mobile/ios/Pods/
mobile/ios/build/
mobile/ios/*.xcworkspace
mobile/ios/*.xcuserdata
mobile/ios/DerivedData/
mobile/ios/*.hmap
mobile/ios/*.ipa
mobile/ios/*.dSYM.zip
mobile/ios/*.dSYM

# Bundler Metro
.metro-health-check*

# ============================================
# LANDING WEB
# ============================================
# Builds de Next.js / React / Vite
web/.next/
web/out/
web/build/
web/dist/

# Caché de assets estáticos
web/.cache/

# ============================================
# PANEL DE ADMINISTRACIÓN
# ============================================
# Builds
admin/.next/
admin/out/
admin/build/
admin/dist/

# ============================================
# BACKEND / SERVIDOR
# ============================================
# Builds
server/dist/
server/build/

# Logs
server/logs/
*.log

# Bases de datos locales
*.sqlite
*.sqlite3
*.db

# ============================================
# TESTS Y COBERTURA
# ============================================
coverage/
*.coverage
.nyc_output/
.jest/

# ============================================
# IDEs Y EDITORES
# ============================================
# VS Code
.vscode/
*.code-workspace

# IntelliJ IDEA
.idea/
*.iml
*.iws
*.ipr

# WebStorm
.idea/

# Sublime Text
*.sublime-project
*.sublime-workspace

# Vim
*.swp
*.swo
*~

# ============================================
# SISTEMA OPERATIVO
# ============================================
# macOS
.DS_Store
.AppleDouble
.LSOverride
._*

# Windows
Thumbs.db
Thumbs.db:encryptable
ehthumbs.db
ehthumbs_vista.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~
.directory
.Trash-*

# ============================================
# ARCHIVOS TEMPORALES
# ============================================
*.tmp
*.temp
*.cache
*.bak
*.swp
*.swo

# ============================================
# BUILD Y DESPLIEGUE
# ============================================
# Artefactos de build móvil
*.apk
*.aab
*.ipa
*.app

# Despliegue
.vercel/
.netlify/

# ============================================
# DOCUMENTACIÓN (opcional, descomentar si se usa)
# ============================================
# docs/build/
# docs/.docusaurus/

# ============================================
# VARIOS
# ============================================
.turbo/
.parcel-cache/
.cache/
